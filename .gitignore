/public/
/public-preview/
/resources/_gen/
/.hugo_build.lock

# Self-contained preview HTML (generated by scripts/make-preview.py)
/preview/

# Only content/posts/ is published. Everything else under content/ (Korean
# drafts, scratch, etc.) stays local and is never committed.
/content/*
!/content/posts/

